<Window x:Class="ProcessDirector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessDirector.ViewModels"
        xmlns:models="clr-namespace:ProcessDirector.AppData"
        xmlns:converters="clr-namespace:ProcessDirector"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        mc:Ignorable="d"
        Title="Process Director" 
        Height="750" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <converters:CategoryNameConverter x:Key="CategoryNameConverter"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7" Opacity="0.8"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#333333"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogButton" TargetType="Button">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D8D8D8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0078D7"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="#0078D7"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0078D7"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <CollectionViewSource x:Key="GroupedProcessesSource" Source="{Binding AllProcesses}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="DisplayCategory"/>
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="DisplayCategory" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="1" Padding="6" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CPU:" FontWeight="Bold" FontSize="12" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CpuTemperature}" FontSize="12" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding CpuLoad}" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GPU:" FontWeight="Bold" FontSize="12" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding GpuTemperature}" FontSize="12" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding GpuLoad}" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RAM:" FontWeight="Bold" FontSize="12" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding RamUsage}" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Процессов:" FontSize="11" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ProcessCount}" FontWeight="Bold" FontSize="12"/>
                </StackPanel>

                <Button Grid.Column="4" Style="{StaticResource SettingsButton}" 
                        Content="⚙ Настройки" Margin="15,0,0,0"
                        Command="{Binding OpenSettingsCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,6,0">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="4" Margin="0,0,0,4">
                        <WrapPanel>
                            <Button Style="{StaticResource ActionButton}" Content="Обновить" Command="{Binding RefreshCommand}"/>
                            <Button Style="{StaticResource ActionButton}" Content="Завершить процесс" Command="{Binding KillProcessCommand}"/>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#F0F0F0" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="6,3" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="25"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Имя" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                            <TextBlock Grid.Column="2" Text="PID" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                            <TextBlock Grid.Column="3" Text="Память" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                            <TextBlock Grid.Column="4" Text="CPU" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="2"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="False"
                             ItemsSource="{Binding Source={StaticResource GroupedProcessesSource}}"
                             SelectedItem="{Binding SelectedProcess}"
                             BorderThickness="0"
                             Background="#FFFFFF"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             IsSynchronizedWithCurrentItem="True">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Завершить процесс" Command="{Binding KillProcessCommand}"/>
                                <MenuItem Header="Завершить дерево процессов" Command="{Binding KillProcessTreeCommand}"/>
                                <MenuItem Header="Заморозить" Command="{Binding FreezeProcessCommand}"/>
                                <MenuItem Header="Разморозить" Command="{Binding UnfreezeProcessCommand}"/>
                                <MenuItem Header="Открыть расположение файла" Command="{Binding OpenFileLocationCommand}"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#E8E8E8" Padding="6,3" Margin="0,4,0,2" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding Name, Converter={StaticResource CategoryNameConverter}}" FontWeight="Bold" FontSize="12" Foreground="#333"/>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ProcessInfo}">
                                <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="6,4" Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="25"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Source="{Binding Icon}" Width="16" Height="16" VerticalAlignment="Center">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Opacity" Value="0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Id}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBlock Grid.Column="3" Text="{Binding MemoryFormatted}" FontSize="11" VerticalAlignment="Center" Foreground="#555"/>
                                        <TextBlock Grid.Column="4" Text="{Binding CpuFormatted}" FontSize="11" VerticalAlignment="Center" Foreground="#555"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Логирование" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,6"/>

                    <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="6" Margin="0,0,0,6">
                        <StackPanel>
                            <WrapPanel>
                                <Button Style="{StaticResource LogButton}" Content="Старт" Command="{Binding StartLoggingCommand}"/>
                                <Button Style="{StaticResource LogButton}" Content="Стоп" Command="{Binding StopLoggingCommand}"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,4,0,0">
                                <Button Style="{StaticResource LogButton}" Content="Открыть папку" Command="{Binding OpenLogFolderCommand}"/>
                                <Button Style="{StaticResource LogButton}" Content="Открыть файл" Command="{Binding OpenCurrentLogCommand}"/>
                            </WrapPanel>
                            <Border Background="#E8F0F8" BorderBrush="#CCCCCC" BorderThickness="1" Padding="6" Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#333" Text="{Binding LogStatus}"/>
                                    <TextBlock FontSize="9" Foreground="#666" Text="{Binding CurrentLogFilePath}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" Padding="4" Margin="0,0,0,6" x:Name="LogBorder">
                        <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ListBox ItemsSource="{Binding LogEntries}"
                                     SelectedItem="{Binding SelectedLogEntry, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource LogListBoxItem}"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Завершить процесс" Command="{Binding KillProcessFromLogCommand}"/>
                                        <MenuItem Header="Завершить дерево процессов" Command="{Binding KillProcessTreeFromLogCommand}"/>
                                        <MenuItem Header="Заморозить" Command="{Binding FreezeProcessFromLogCommand}"/>
                                        <MenuItem Header="Разморозить" Command="{Binding UnfreezeProcessFromLogCommand}"/>
                                        <MenuItem Header="Открыть расположение файла" Command="{Binding OpenFileLocationFromLogCommand}"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="10" Foreground="#D4D4D4" Margin="0,1,0,1" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="3" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="6">
                        <TextBlock Text="{Binding LogDirectory}" FontSize="9" Foreground="#555" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="1" Padding="4" Margin="0,6,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="10" Foreground="#555"/>
        </Border>
    </Grid>
</Window>