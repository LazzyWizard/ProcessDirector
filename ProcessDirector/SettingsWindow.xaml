<Window x:Class="ProcessDirector.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки Process Director" 
        Height="650" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox" x:Key="HotkeyTextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Text" Value="Нажмите для установки..."/>
            <Setter Property="Foreground" Value="#999999"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="BorderBrush" Value="#0078D7"/>
                    <Setter Property="Text" Value="Нажмите сочетание клавиш..."/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="180"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Настройки Process Director" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <GroupBox Header="Папка для логов">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding LogFolderPath}" 
                                 Background="#F0F0F0" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="..." Width="40" Margin="5,0,0,0"
                                Click="SelectLogFolder_Click"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="SuperF4 — экстренное завершение окна">
                    <StackPanel>
                        <CheckBox Content="Включить SuperF4" IsChecked="{Binding SuperF4Enabled}"/>
                        <StackPanel Orientation="Horizontal" Margin="20,5,0,0">
                            <Label Content="Сочетание клавиш:"/>
                            <TextBox x:Name="SuperF4TextBox" Style="{StaticResource HotkeyTextBox}"
                                     GotFocus="HotkeyTextBox_GotFocus"
                                     LostFocus="HotkeyTextBox_LostFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"/>
                        </StackPanel>
                        <TextBlock FontSize="11" Foreground="#666" Margin="20,5,0,0">
                            По умолчанию: Ctrl + Alt + F4
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Горячие клавиши">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <CheckBox Content="Обновление процессов" Width="180" 
                                      IsChecked="{Binding RefreshEnabled}"/>
                            <TextBox x:Name="RefreshTextBox" Style="{StaticResource HotkeyTextBox}"
                                     GotFocus="HotkeyTextBox_GotFocus"
                                     LostFocus="HotkeyTextBox_LostFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <CheckBox Content="Старт логирования" Width="180" 
                                      IsChecked="{Binding StartLoggingEnabled}"/>
                            <TextBox x:Name="StartLoggingTextBox" Style="{StaticResource HotkeyTextBox}"
                                     GotFocus="HotkeyTextBox_GotFocus"
                                     LostFocus="HotkeyTextBox_LostFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <CheckBox Content="Стоп логирования" Width="180" 
                                      IsChecked="{Binding StopLoggingEnabled}"/>
                            <TextBox x:Name="StopLoggingTextBox" Style="{StaticResource HotkeyTextBox}"
                                     GotFocus="HotkeyTextBox_GotFocus"
                                     LostFocus="HotkeyTextBox_LostFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <CheckBox Content="Завершить выделенный процесс" Width="180" 
                                      IsChecked="{Binding KillProcessEnabled}"/>
                            <TextBox x:Name="KillProcessTextBox" Style="{StaticResource HotkeyTextBox}"
                                     GotFocus="HotkeyTextBox_GotFocus"
                                     LostFocus="HotkeyTextBox_LostFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"/>
                        </StackPanel>

                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Width="100" Background="#4CAF50" Foreground="White" 
                    BorderBrush="#388E3C" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>